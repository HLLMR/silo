{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Silo",
  "version": "0.1.0",
  "identifier": "com.hllmr.silo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Silo",
        "width": 1400,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 680,
        "backgroundColor": "#171A14",
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost https://*.giants-software.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
